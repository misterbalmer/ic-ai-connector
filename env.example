# IC AI Connector — Live Binance Futures account
# Copy to .env and fill in. NEVER commit .env.

# === REQUIRED ===
BINANCE_API_KEY=your_binance_futures_api_key_here
BINANCE_API_SECRET=your_binance_futures_api_secret_here

# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
CONNECTOR_TOKEN=replace_with_at_least_32_character_random_string

# Live account acknowledgment (required)
LIVE_TRADING_ACK=I_ACCEPT_LIVE_RISK

# === SAFETY ===
TRADE_MODE=auto
# TRADE_MODE=confirm

# === RISK LIMITS (enforced server-side) ===
MAX_NOTIONAL_PER_ORDER=200
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS=100
MAX_LEVERAGE=20
MAX_MARGIN_LOSS_ON_STOP=0.35
MIN_NOTIONAL_USDT=5
PROPOSAL_TTL_SECONDS=300

# === SERVER ===
# Receiver bind (operator maps http://ic.snapshot:8080 — add to hosts: 127.0.0.1 ic.snapshot)
CONNECTOR_HOST=127.0.0.1
CONNECTOR_PORT=8080

# AI analysis cycle (Konsole snapshot interval, seconds)
DECISION_INTERVAL_SECONDS=900
